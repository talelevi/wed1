# Copy to `.env.local` and fill in your Supabase project values.
# When BOTH variables are set, the RSVP panel uses the cloud table `rsvps`.
# When either is missing, RSVP falls back to localStorage automatically.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Identifier for the event bucket inside the `rsvps` table.
# Set per couple (e.g. "dana-omer-2026") so multiple events can share one project.
VITE_DEFAULT_EVENT_ID=default
